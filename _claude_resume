#compdef claude

_claude_resume() {
  local i resume_pos=-1

  # Find if --resume/-r is on the line and where its argument would be
  for (( i=1; i < CURRENT; i++ )); do
    if [[ "${words[$i]}" == "--resume" || "${words[$i]}" == "-r" ]]; then
      resume_pos=$(( i + 1 ))
      break
    fi
  done

  # If we're not completing the --resume argument, fall back to default
  if (( resume_pos != CURRENT )); then
    _default
    return
  fi

  local -a completions
  completions=($(python3 -c "
import json, glob, os, time

now = time.time()

def format_age(ts):
    age = now - ts
    if age < 60:
        return f'{int(age)}s ago'
    elif age < 3600:
        return f'{int(age/60)}m ago'
    elif age < 86400:
        return f'{int(age/3600)}h ago'
    else:
        return f'{int(age/86400)}d ago'

def decode_project_dir(dirname):
    s = dirname.lstrip('-')
    parts = s.split('-')
    path = '/' + parts[0]
    for i in range(1, len(parts)):
        candidate = path + '/' + parts[i]
        joined = path + '-' + parts[i]
        if os.path.isdir(candidate):
            path = candidate
        elif os.path.isdir(joined):
            path = joined
        else:
            path = candidate
    return path

def esc(s):
    return s.replace('\\\\', '\\\\\\\\').replace(':', '\\\\:')

# Load session-meta index
meta = {}
for f in glob.glob(os.path.expanduser('~/.claude/usage-data/session-meta/*.json')):
    sid = os.path.splitext(os.path.basename(f))[0]
    try:
        with open(f) as fh:
            d = json.load(fh)
        meta[sid] = d
    except Exception:
        pass

# Load named sessions
names = {}
for f in glob.glob(os.path.expanduser('~/.claude/sessions/*.json')):
    try:
        with open(f) as fh:
            d = json.load(fh)
        name = d.get('name', '')
        sid = d.get('sessionId', '')
        if name and sid:
            names[sid] = name
    except Exception:
        pass

# Collect all sessions from projects
cwd = os.getcwd()
cwd_encoded = cwd.replace('/', '-')
local_sessions = []
other_sessions = []
for proj_dir in glob.glob(os.path.expanduser('~/.claude/projects/*')):
    dirname = os.path.basename(proj_dir)
    is_local = (dirname == cwd_encoded)
    for f in glob.glob(os.path.join(proj_dir, '*.jsonl')):
        try:
            sid = os.path.splitext(os.path.basename(f))[0]
            mtime = os.path.getmtime(f)
            entry = (mtime, sid, dirname)
            if is_local:
                local_sessions.append(entry)
            else:
                other_sessions.append(entry)
        except Exception:
            pass

local_sessions.sort(key=lambda x: -x[0])
other_sessions.sort(key=lambda x: -x[0])
sessions = local_sessions + other_sessions

seen = set()
for mtime, sid, dirname in sessions[:30]:
    if sid in seen:
        continue
    seen.add(sid)

    age = format_age(mtime)

    m = meta.get(sid)
    if m and m.get('project_path'):
        proj = os.path.basename(m['project_path'])
    else:
        proj = os.path.basename(decode_project_dir(dirname))

    parts = [age, proj]
    if sid in names:
        parts.append(names[sid])
    elif m and m.get('first_prompt', '') not in ('', 'No prompt'):
        snippet = m['first_prompt'][:40].replace('\\n', ' ')
        parts.append(snippet)

    desc = ' | '.join(parts)
    print(f'{esc(sid)}:{esc(desc)}')
" 2>/dev/null))

  _describe 'session' completions
}

_claude_resume "$@"
