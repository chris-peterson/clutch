#compdef claude
# Custom completion for the claude CLI.
# Waiting for claude to ship official completions; remove this once they do.

_claude() {
  local i resume_pos=-1

  # Check if --resume/-r is already on the line and find where its argument goes
  for (( i=1; i < CURRENT; i++ )); do
    if [[ "${words[$i]}" == "--resume" || "${words[$i]}" == "-r" ]]; then
      resume_pos=$(( i + 1 ))
      break
    fi
  done

  # Complete the --resume argument with sessions (most recent first)
  if (( resume_pos == CURRENT )); then
    _claude_resume_sessions
    return
  fi

  # Complete flags and subcommands
  local -a flags=(
    '--add-dir[Additional directories to allow tool access to]:directory:_directories'
    '--agent[Agent for the current session]:agent:'
    '--allowedTools[Tool names to allow]:tools:'
    '--append-system-prompt[Append to the default system prompt]:prompt:'
    '--bare[Minimal mode: skip hooks, LSP, plugins, auto-memory]'
    {-c,--continue}'[Continue the most recent conversation]'
    {-d,--debug}'[Enable debug mode]'
    '--disallowedTools[Tool names to deny]:tools:'
    '--effort[Effort level (low, medium, high, max)]:level:(low medium high max)'
    '--fork-session[Create a new session ID when resuming]'
    '--from-pr[Resume a session linked to a PR]:pr:'
    {-h,--help}'[Display help]'
    '--model[Model for the current session]:model:(sonnet opus haiku)'
    {-n,--name}'[Set a display name for this session]:name:'
    '--permission-mode[Permission mode]:mode:(acceptEdits bypassPermissions default dontAsk plan auto)'
    {-p,--print}'[Print response and exit]'
    {-r,--resume}'[Resume a conversation]:session:_claude_resume_sessions'
    '--system-prompt[System prompt for the session]:prompt:'
    '--verbose[Override verbose mode setting]'
    {-v,--version}'[Output the version number]'
    {-w,--worktree}'[Create a new git worktree]'
  )

  local -a subcommands=(
    'agents:List configured agents'
    'auth:Manage authentication'
    'doctor:Check auto-updater health'
    'install:Install Claude Code native build'
    'mcp:Configure and manage MCP servers'
    'plugin:Manage Claude Code plugins'
    'setup-token:Set up a long-lived auth token'
    'update:Check for updates and install'
  )

  _arguments -s -S \
    $flags \
    '1: :_describe "command" subcommands' \
    '*: :_default'
}

_claude_resume_sessions() {
  local -a completions
  completions=("${(f)$(python3 -c "
import json, glob, os, time

now = time.time()

def format_age(ts):
    age = now - ts
    if age < 60:
        return f'{int(age)}s ago'
    elif age < 3600:
        return f'{int(age/60)}m ago'
    elif age < 86400:
        return f'{int(age/3600)}h ago'
    else:
        return f'{int(age/86400)}d ago'

def esc(s):
    return s.replace('\\\\', '\\\\\\\\').replace(':', '\\\\:')

# Load session-meta index
meta = {}
for f in glob.glob(os.path.expanduser('~/.claude/usage-data/session-meta/*.json')):
    sid = os.path.splitext(os.path.basename(f))[0]
    try:
        with open(f) as fh:
            d = json.load(fh)
        meta[sid] = d
    except Exception:
        pass

# Load named sessions
names = {}
for f in glob.glob(os.path.expanduser('~/.claude/sessions/*.json')):
    try:
        with open(f) as fh:
            d = json.load(fh)
        name = d.get('name', '')
        sid = d.get('sessionId', '')
        if name and sid:
            names[sid] = name
    except Exception:
        pass

cwd = os.getcwd()
cwd_encoded = cwd.replace('/', '-')
local_sessions = []
proj_dir = os.path.expanduser('~/.claude/projects/' + cwd_encoded)
if os.path.isdir(proj_dir):
    for f in glob.glob(os.path.join(proj_dir, '*.jsonl')):
        try:
            sid = os.path.splitext(os.path.basename(f))[0]
            mtime = os.path.getmtime(f)
            local_sessions.append((mtime, sid))
        except Exception:
            pass

local_sessions.sort(key=lambda x: -x[0])

seen = set()
for mtime, sid in local_sessions[:30]:
    if sid in seen:
        continue
    seen.add(sid)

    age = format_age(mtime)

    m = meta.get(sid)
    proj = os.path.basename(cwd)

    parts = [age, proj]
    if sid in names:
        parts.append(names[sid])
    elif m and m.get('first_prompt', '') not in ('', 'No prompt'):
        snippet = m['first_prompt'][:40].replace('\\n', ' ')
        parts.append(snippet)

    desc = ' | '.join(parts)
    print(f'{esc(sid)}:{esc(desc)}')
" 2>/dev/null)}")

  _describe 'session' completions
}

_claude "$@"
